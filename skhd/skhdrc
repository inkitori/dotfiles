# skhd — keyboard daemon driving yabai. Every bind below is a 1:1 wrapper
# around a yabai command. See `man skhd` for syntax, `man yabai` / `yabai -h`
# for the underlying ops. skhd hot-reloads on file save.
#
# ── CHEATSHEET ───────────────────────────────────────────────────────────────
#
# Focus
#   alt - h / j / k / l       focus window: west / south / north / east
#                             (falls through to next display at edges)
#   alt - n / p               cycle stack: next / prev window
#
# Move
#   alt + shift - h/j/k/l     swap with neighbor (preserves split)
#   alt + ctrl  - h/j/k/l     warp (move + reparent in bsp tree)
#   alt + cmd   - h/j/k/l     resize 48px toward direction
#   alt + cmd   - 0           balance all tile sizes in space
#
# Window state
#   alt - m                   zoom-fullscreen (max within parent)
#   alt - g                   zoom-parent (grow into grandparent's space)
#   alt - e                   split toggle (rotate horizontal / vertical)
#   alt - v                   insert: next new window opens south
#   alt - z                   insert: next new window opens east
#   alt + shift - f           native macOS fullscreen (own space)         [SA]
#   alt + shift - t           toggle float (centered grid)
#   alt + ctrl  - p           toggle sticky (pin across all spaces)       [SA]
#
# Spaces — focus
#   alt - 1 .. 0              focus space N  (alt-0 = space 10)
#   alt - f                   focus firefox space
#   alt - d                   focus discord space
#   alt - t                   focus cmux space         (T = terminal)
#   alt - s                   focus spotify space
#   alt - c                   focus code space         (C = VS Code)
#   alt - a                   focus slack space
#   alt - i                   focus claude space       (I = AI)
#   alt - o                   quick-open inkcal.sh (launches if needed) + focus
#   ctrl + alt - left/right   focus prev / next space
#
# Spaces — send focused window (and follow)
#   alt + shift - 1 .. 0                  by number
#   ctrl + alt + shift - f/d/t/s/c/a/i/o  by label (same letters as focus)
#
# Space layout
#   alt + shift - s           toggle bsp ↔ stack
#   alt + shift - r           rotate space 90°
#   alt + shift - x / y       mirror across x / y axis
#
# System
#   alt - return              launch new Ghostty terminal
#   alt + ctrl - o            organize: re-apply rules to all windows
#   alt + ctrl - r            reload yabai + skhd, then re-organize
#
# [SA] = requires the scripting addition (see yabairc top-of-file setup).
#
# ── CONVENTIONS ──────────────────────────────────────────────────────────────
# alt           primary yabai modifier — kept friction-free for frequent ops
# alt + shift   "this op, but affecting other windows / sending to other spaces"
# alt + ctrl    "rearrange / system-level" (warp, organize, reload, sticky)
# alt + cmd     reserved for resize
# cmd alone     reserved for app shortcuts (cmd-c/v/w/…); yabai never claims it
# ctrl alone    reserved for terminals + readline
# alt + arrow   reserved by macOS for word-jumping — that's why prev/next
#               space uses ctrl + alt + arrow instead.
# ─────────────────────────────────────────────────────────────────────────────


# ---------------------------------------------------------------------------
# focus — fall-through to display focus is guarded by a `query --display DIR`
# check. Without the guard, hitting an edge in single-monitor mode could leave
# focus in a half-detached state (no window claimed) instead of a clean no-op.
# ---------------------------------------------------------------------------
alt - h : yabai -m window --focus west  || ( yabai -m query --displays --display west  >/dev/null 2>&1 && yabai -m display --focus west  )
alt - j : yabai -m window --focus south || ( yabai -m query --displays --display south >/dev/null 2>&1 && yabai -m display --focus south )
alt - k : yabai -m window --focus north || ( yabai -m query --displays --display north >/dev/null 2>&1 && yabai -m display --focus north )
alt - l : yabai -m window --focus east  || ( yabai -m query --displays --display east  >/dev/null 2>&1 && yabai -m display --focus east  )

alt - n : yabai -m window --focus next || yabai -m window --focus first
alt - p : yabai -m window --focus prev || yabai -m window --focus last

# ---------------------------------------------------------------------------
# swap — exchange positions, preserving split. Falls through to --toggle split
# when there's no neighbor in that direction (e.g. pressing alt+shift+j on a
# left/right pair flips them to top/bottom instead of no-op'ing).
# ---------------------------------------------------------------------------
alt + shift - h : yabai -m window --swap west  || yabai -m window --toggle split
alt + shift - j : yabai -m window --swap south || yabai -m window --toggle split
alt + shift - k : yabai -m window --swap north || yabai -m window --toggle split
alt + shift - l : yabai -m window --swap east  || yabai -m window --toggle split

# ---------------------------------------------------------------------------
# warp — move window AND reparent in the bsp tree (changes split structure)
# ---------------------------------------------------------------------------
alt + ctrl - h : yabai -m window --warp west
alt + ctrl - j : yabai -m window --warp south
alt + ctrl - k : yabai -m window --warp north
alt + ctrl - l : yabai -m window --warp east

# ---------------------------------------------------------------------------
# resize — first form tries growing toward direction; falls back to shrinking
# from the opposite edge if the window is on a screen edge
# ---------------------------------------------------------------------------
alt + cmd - h : yabai -m window --resize left:-48:0  || yabai -m window --resize right:-48:0
alt + cmd - l : yabai -m window --resize right:48:0  || yabai -m window --resize left:48:0
alt + cmd - k : yabai -m window --resize top:0:-48   || yabai -m window --resize bottom:0:-48
alt + cmd - j : yabai -m window --resize bottom:0:48 || yabai -m window --resize top:0:48
alt + cmd - 0 : yabai -m space  --balance

# ---------------------------------------------------------------------------
# window state — zoom, float, fullscreen, split direction, sticky, insert
# ---------------------------------------------------------------------------
alt - m         : yabai -m window --toggle zoom-fullscreen
alt - g         : yabai -m window --toggle zoom-parent
alt - e         : yabai -m window --toggle split
alt - v         : yabai -m window --insert south
alt - z         : yabai -m window --insert east
alt + shift - f : yabai -m window --toggle native-fullscreen
alt + shift - t : yabai -m window --toggle float --grid 8:8:1:1:6:6
alt + ctrl  - p : yabai -m window --toggle sticky

# ---------------------------------------------------------------------------
# spaces — focus by number  (skhd captures alt-N before macOS makes special chars)
# ---------------------------------------------------------------------------
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9
alt - 0 : yabai -m space --focus 10

# spaces — focus by label (mirrors yabairc's space 1..7 labels)
alt - f : yabai -m space --focus firefox
alt - d : yabai -m space --focus discord
alt - t : yabai -m space --focus cmux
alt - s : yabai -m space --focus spotify
alt - c : yabai -m space --focus code
alt - a : yabai -m space --focus slack
alt - i : yabai -m space --focus claude

# quick-open: launch inkcal.sh if not running (rule routes it to inkcal space),
# then focus the space. `open -a` is idempotent — activates if already running.
alt - o : yabai -m space --focus inkcal; open -a inkcal.sh

# spaces — prev/next (alt-arrow stays free for macOS word-jumping in text)
ctrl + alt - left  : yabai -m space --focus prev
ctrl + alt - right : yabai -m space --focus next

# ---------------------------------------------------------------------------
# send focused window to a space (and follow it)
# ---------------------------------------------------------------------------
alt + shift - 1 : yabai -m window --space 1;  yabai -m space --focus 1
alt + shift - 2 : yabai -m window --space 2;  yabai -m space --focus 2
alt + shift - 3 : yabai -m window --space 3;  yabai -m space --focus 3
alt + shift - 4 : yabai -m window --space 4;  yabai -m space --focus 4
alt + shift - 5 : yabai -m window --space 5;  yabai -m space --focus 5
alt + shift - 6 : yabai -m window --space 6;  yabai -m space --focus 6
alt + shift - 7 : yabai -m window --space 7;  yabai -m space --focus 7
alt + shift - 8 : yabai -m window --space 8;  yabai -m space --focus 8
alt + shift - 9 : yabai -m window --space 9;  yabai -m space --focus 9
alt + shift - 0 : yabai -m window --space 10; yabai -m space --focus 10

# send to labeled space — letter matches the alt-<letter> focus binds above
ctrl + alt + shift - f : yabai -m window --space firefox; yabai -m space --focus firefox
ctrl + alt + shift - d : yabai -m window --space discord; yabai -m space --focus discord
ctrl + alt + shift - t : yabai -m window --space cmux;    yabai -m space --focus cmux
ctrl + alt + shift - s : yabai -m window --space spotify; yabai -m space --focus spotify
ctrl + alt + shift - c : yabai -m window --space code;    yabai -m space --focus code
ctrl + alt + shift - a : yabai -m window --space slack;   yabai -m space --focus slack
ctrl + alt + shift - i : yabai -m window --space claude;   yabai -m space --focus claude
ctrl + alt + shift - o : yabai -m window --space inkcal; yabai -m space --focus inkcal

# ---------------------------------------------------------------------------
# space layout — rotate, mirror, bsp ↔ stack
# ---------------------------------------------------------------------------
alt + shift - r : yabai -m space --rotate 270
alt + shift - x : yabai -m space --mirror x-axis
alt + shift - y : yabai -m space --mirror y-axis

alt + shift - s : \
    if [[ $(yabai -m query --spaces --space | jq -r '.type') == "bsp" ]]; then \
        yabai -m space --layout stack; \
    else \
        yabai -m space --layout bsp; \
    fi

# ---------------------------------------------------------------------------
# system — launcher, organize, reload
# ---------------------------------------------------------------------------
alt - return : open -na Ghostty

# Re-apply yabai rules to all existing windows. Sweeps Firefox/Discord/cmux/etc.
# back to their assigned spaces if they got dragged elsewhere.
alt + ctrl - o : \
    yabai -m rule --apply; \
    osascript -e 'display notification "windows organized" with title "wm"'

# Full reload. The 0.5s sleep gives yabai time to come back up before we ask
# it to re-apply rules — without it, --apply races the service restart.
alt + ctrl - r : \
    yabai --restart-service; \
    skhd  --restart-service; \
    sleep 0.5; \
    yabai -m rule --apply; \
    osascript -e 'display notification "yabai + skhd reloaded" with title "wm"'
