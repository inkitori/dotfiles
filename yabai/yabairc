#!/usr/bin/env sh
# yabai window manager — bsp tiling on macOS. Paired with:
#   - skhd     (~/Dotfiles/skhd/skhdrc)        keyboard binds; see its cheatsheet
#   - borders  (~/Dotfiles/borders/bordersrc)  pink border around focused window
#   - colors   (~/.config/colors.sh)           shared palette sourced below
#
# This config sets up bsp tiling, six labeled spaces (one per pinned app —
# Firefox, Discord, cmux, Spotify, VS Code, Slack), gentle animations,
# inactive-window fade, and a mouse-drag-to-swap gesture. Apple-protected
# windows (System Settings, Finder, …) are forced to float.
#
# ── SCRIPTING ADDITION (SA) ──────────────────────────────────────────────────
# Required for: window animations, native fullscreen, mouse-swap-on-drop,
# sticky toggle, programmatic space create/destroy, and forced positioning of
# Apple-protected apps. Plain tiling/spaces/rules/skhd binds work without it.
#
# One-time setup:
#   1. Partial SIP disable — boot to Recovery (hold power on Apple Silicon),
#      lower Startup Security to "Reduced Security", then in Recovery Terminal:
#        csrutil enable --without fs --without debug --without nvram
#   2. Apple Silicon only — PAC ABI compat boot-arg, then reboot:
#        sudo nvram boot-args=-arm64e_preview_abi
#   3. NOPASSWD sudoers entry (so dock_did_restart can auto-load SA silently):
#        sudo visudo -f /private/etc/sudoers.d/yabai
#        # echo "$(whoami) ALL=(root) NOPASSWD: sha256:$(shasum -a 256 $(which yabai) | cut -d' ' -f1) $(which yabai) --load-sa"
#   4. Install + patch + inject SA. Sequoia builds need a PAC ABI byte-patch
#      (https://github.com/asmvik/yabai/issues/2686 — known upstream regression):
#        sudo yabai --load-sa                       # installs loader; inject will fail
#        sudo ~/Dotfiles/yabai/patch-sa-pac-abi.sh  # flips 0x81 → 0x80, re-signs
#        sudo yabai --load-sa                       # injects (silent = success)
#   5. Grant yabai Screen Recording permission (System Settings → Privacy &
#      Security → Screen Recording → +/opt/homebrew/bin/yabai). Required for
#      animations to actually run; without it, the duration setting silently
#      no-ops with a log warning.
#
# After setup the dock_did_restart signal below auto-injects on every login —
# no manual work, no password prompts.
#
# After `brew upgrade yabai`: just run `~/Dotfiles/yabai/post-upgrade.sh` — it
# refreshes the sudoers hash, re-patches the loader, and re-injects in one go.
# Logs: /tmp/yabai_$USER.{out,err}.log
# ─────────────────────────────────────────────────────────────────────────────
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa" 2>/dev/null || true

source "$HOME/.config/colors.sh"

# ── global config ────────────────────────────────────────────────────────────
yabai -m config                                 \
    mouse_follows_focus          off            \
    focus_follows_mouse          autofocus      \
    window_origin_display        default        \
    window_placement             second_child   \
    window_zoom_persist          off            \
    window_shadow                float          \
    window_animation_duration    0.15           \
    window_opacity_duration      0.10           \
    active_window_opacity        1.0            \
    normal_window_opacity        0.92           \
    window_opacity               on             \
    insert_feedback_color        "$COLOR_ACCENT" \
    split_ratio                  0.50           \
    split_type                   auto           \
    auto_balance                 off            \
    top_padding                  12             \
    bottom_padding               12             \
    left_padding                 12             \
    right_padding                12             \
    window_gap                   10             \
    layout                       bsp            \
    mouse_modifier               fn             \
    mouse_action1                move           \
    mouse_action2                resize         \
    mouse_drop_action            swap

# ── float rules — apps that should never tile ────────────────────────────────
yabai -m rule --add app="^(System Settings|System Information|Activity Monitor|FaceTime|Screen Sharing|Calculator|Stickies|TinkerTool|Progressive Downloader|Transmission|Airflow|Raycast|Karabiner-Elements|LinearMouse|Finder|Webull Desktop|App Store|Software Update)$" manage=off
yabai -m rule --add title="(Preferences|Settings|Welcome)$" manage=off

# ── spaces — ensure 6 exist, then label each one ─────────────────────────────
# `space --create` requires SA. Idempotent: skips if you already have ≥ 6.
# Without this, focusing a missing label (e.g. alt-a slack) silently no-ops,
# and rules can't move windows to nonexistent target spaces.
NEEDED_SPACES=6
HAVE_SPACES=$(yabai -m query --spaces | jq 'length')
while [ "$HAVE_SPACES" -lt "$NEEDED_SPACES" ]; do
    yabai -m space --create
    HAVE_SPACES=$((HAVE_SPACES + 1))
done

# Labels referenced by skhd's alt-<letter> binds and the app→space rules below.
yabai -m space 1 --label firefox 2>/dev/null
yabai -m space 2 --label discord 2>/dev/null
yabai -m space 3 --label cmux    2>/dev/null
yabai -m space 4 --label spotify 2>/dev/null
yabai -m space 5 --label code    2>/dev/null
yabai -m space 6 --label slack   2>/dev/null

# ── app → space pinning (SA required to actually move windows) ───────────────
yabai -m rule --add app="^Firefox$"  space=firefox
yabai -m rule --add app="^Vesktop$"  space=discord
yabai -m rule --add app="^cmux$"     space=cmux
yabai -m rule --add app="^Spotify$"  space=spotify
yabai -m rule --add app="^Code$"     space=code
yabai -m rule --add app="^Slack$"    space=slack

# ── signals ──────────────────────────────────────────────────────────────────
# Ghostty occasionally lands a window before yabai sees it, leaving the space
# in a stale state. Re-issuing the layout forces a re-tile.
yabai -m signal --add app='^Ghostty$' event=window_created   action='yabai -m space --layout bsp'
yabai -m signal --add app='^Ghostty$' event=window_destroyed action='yabai -m space --layout bsp'

# ── final pass: sweep existing windows back to their assigned spaces ─────────
# Re-applies all rules to currently-managed windows. Run interactively any
# time via `alt + ctrl - o` (skhd binding).
yabai -m rule --apply

echo "yabai configuration loaded.."
