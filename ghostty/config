# Everforest Dark — mint green + salmon + cream on dark grey, very readable.
# (Pink config preserved at ./config-pink — swap by copying it over this file.)
theme = Everforest Dark Hard

# get a Nerd Font so icons render — install via brew first
font-family = JetBrainsMono Nerd Font
font-size = 14

# Solid background. Unlike the pink config, we're not overriding `background`,
# so adding `background-blur` here would actually work — but for max
# readability of code, keep it opaque. To get a glassy look, try:
background-opacity = 0.92
background-blur = true

# breathing room
window-padding-x = 16
window-padding-y = 12
window-padding-balance = true

# hide ghostty's tab bar — cmux has its own vertical tabs
window-show-tab-bar = never

# nice cursor
cursor-style = block
cursor-style-blink = false
